{
  "appId": "foxglove",
  "version": "0.1.0",
  "platform": "linux",
  "services": {
    "bridge": {
      "context": "./bridge",
      "entitlements": [{ "type": "network", "mode": "host" }]
    },
    "camera": {
      "context": "./camera",
      "dependsOn": ["bridge"],
      "entitlements": [{ "type": "network", "mode": "host" }]
    },
    "control": {
      "context": "./control",
      "entitlements": [{ "type": "network", "mode": "host" }]
    }
  }
}
